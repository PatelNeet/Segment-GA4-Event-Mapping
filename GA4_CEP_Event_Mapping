function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function cepChip(p){const req=/\*$/.test(p),name=p.replace(/\*+$/,'');return req?`<span class="cp cp-r">${esc(name)}<sup>*</sup></span>`:`<span class="cp">${esc(name)}</span>`;}
function ga4Rows(arr){return arr.map(([n,src])=>`<tr><td>${esc(n)}</td><td>${src?esc(src):'<span style=\"color:var(--txt-3)\">&mdash;</span>'}</td></tr>`).join('');}
function chips(arr,scopeCls,scopeLbl){return `<div class="sec-sub">${scopeLbl} <span class="${scopeCls}">${scopeCls==='sc-e'?'event':scopeCls==='sc-i'?'item':'user'}</span></div><div class="cep-chips">${arr.map(cepChip).join('')}</div>`;}
function renderGA4(ev){
  let h=`<div class="ev-lbl"><span class="sc-e" style="font-size:10px">GA4</span>${esc(ev.ga4)}</div>`;
  h+=`<div class="tagref">GTM tag &middot; ${esc(ev.tag)}</div>`;
  if(ev.ge.length){h+=`<div class="sec-sub">Event params <span class="sc-e">event</span></div><table class="pt"><tbody>${ga4Rows(ev.ge)}</tbody></table>`;}
  if(ev.gi.length){h+=`<div class="sec-sub" style="margin-top:10px">Item params <span class="sc-i">items[]</span></div><table class="pt"><tbody>${ga4Rows(ev.gi)}</tbody></table>`;}
  if(ev.gu.length){h+=`<div class="sec-sub" style="margin-top:10px">User params <span class="sc-u">user</span></div><table class="pt"><tbody>${ga4Rows(ev.gu)}</tbody></table>`;}
  if(!ev.ge.length&&!ev.gi.length&&!ev.gu.length){h+=`<p class="none-note">No event-specific parameters documented in the mapping sheet.</p>`;}
  return h;
}
function renderCEP(ev){
  if(!ev.ceps||!ev.ceps.length)return`<div class="none-note">No direct CEP mapping. This GA4 event is tracked in the legacy GA4 / data-layer setup only &mdash; there is no corresponding CEP event.</div>`;
  return ev.ceps.map(cp=>{
    let h=`<div class="cep-block"><div class="ev-lbl"><span class="sc-i" style="font-size:10px">CEP</span>${esc(cp.name)}</div>`;
    if(cp.fire)h+=`<div class="fire-note"><strong>When to fire:</strong> ${esc(cp.fire)}</div>`;
    if(cp.e&&cp.e.length)h+=chips(cp.e,'sc-e','Event scope');
    if(cp.i&&cp.i.length)h+=`<div style="margin-top:10px">${chips(cp.i,'sc-i','Item / array scope')}</div>`;
    if(cp.u&&cp.u.length)h+=`<div style="margin-top:10px">${chips(cp.u,'sc-u','User scope')}</div>`;
    if(cp.conf)h+=`<div class="glb-note">CEP spec updated &middot; ${esc(cp.conf)}</div>`;
    return h+`</div>`;
  }).join('');
}
function renderDetail(idx){const ev=DATA[idx];return`<div class="det-grid"><div class="det-col"><div class="col-hd"><i class="ti ti-brand-google-analytics" style="font-size:13px"></i>GA4 Event &amp; Parameters</div>${renderGA4(ev)}</div><div class="det-col"><div class="col-hd"><i class="ti ti-layers-subtract" style="font-size:13px"></i>CEP Mapping</div>${renderCEP(ev)}</div></div>`;}
const MT={map:'c-std',multi:'c-multi',none:'c-none'};
const MTL={map:'Mapped',multi:'Multi-map',none:'No CEP'};
const CAT={custom:{c:'cat-custom',l:'Custom'},ecomm:{c:'cat-ecomm',l:'Ecommerce'}};
let openIdx=-1,cur='all';
function toggle(i){
  const dr=document.getElementById('dr-'+i),mr=document.getElementById('mr-'+i),btn=mr.querySelector('.tbtn');
  if(openIdx===i){dr.classList.remove('show');mr.classList.remove('open');btn.classList.remove('open');openIdx=-1;}
  else{
    if(openIdx>=0){const p=document.getElementById('dr-'+openIdx),pm=document.getElementById('mr-'+openIdx);if(p)p.classList.remove('show');if(pm){pm.classList.remove('open');pm.querySelector('.tbtn')?.classList.remove('open');}}
    if(!dr.dataset.loaded){dr.querySelector('td div.di').innerHTML=renderDetail(i);dr.dataset.loaded='1';}
    dr.classList.add('show');mr.classList.add('open');btn.classList.add('open');openIdx=i;
  }
}
function setPill(f,b){document.querySelectorAll('.fb.pill').forEach(x=>x.classList.remove('on'));b.classList.add('on');cur=f;openIdx=-1;go();}
function toggleDD(e){e.stopPropagation();const p=document.getElementById('dd-panel'),b=document.getElementById('dd-btn');p.classList.toggle('open');b.classList.toggle('open');}
document.addEventListener('click',e=>{if(!e.target.closest('.dd')){document.getElementById('dd-panel').classList.remove('open');document.getElementById('dd-btn').classList.remove('open');}});
function ddLabel(sc,se){return sc&&se?'All types':sc?'Custom only':se?'Ecommerce only':'None selected';}
function go(){
  const sc=document.getElementById('f-custom').checked,se=document.getElementById('f-ecomm').checked;
  const base=DATA.map((ev,i)=>({ev,i})).filter(({ev})=>(ev.cat==='custom'&&sc)||(ev.cat==='ecomm'&&se));
  const cAll=base.length,cHas=base.filter(x=>x.ev.mt!=='none').length,cNo=base.filter(x=>x.ev.mt==='none').length,cMul=base.filter(x=>x.ev.mt==='multi').length;
  document.getElementById('c-all').textContent=cAll;
  document.getElementById('c-has').textContent=cHas;
  document.getElementById('c-no').textContent=cNo;
  document.getElementById('c-mul').textContent=cMul;
  document.getElementById('sn-total').textContent=cAll;
  document.getElementById('sn-map').textContent=cHas;
  document.getElementById('sn-no').textContent=cNo;
  document.getElementById('sn-mul').textContent=cMul;
  document.getElementById('dd-state').textContent=ddLabel(sc,se);
  let rows=base.filter(({ev})=>cur==='all'?true:cur==='hascep'?ev.mt!=='none':cur==='nocep'?ev.mt==='none':cur==='multi'?ev.mt==='multi':true);
  const tbl=document.getElementById('tbl');
  if(!rows.length){tbl.innerHTML=`<tr><td colspan="4" style="padding:26px;text-align:center;color:var(--txt-3)">No events match the current filters.</td></tr>`;document.getElementById('shown-count').textContent='0';return;}
  tbl.innerHTML=rows.map(({ev,i})=>{
    const cat=CAT[ev.cat];
    const cepCell=ev.mt==='none'?`<span class="pll c-none" style="opacity:.55">No direct mapping</span>`:ev.cep_names.map(x=>`<span class="pll ${MT[ev.mt]}">${esc(x)}</span>`).join('');
    return `<tr class="mr" id="mr-${i}" onclick="toggle(${i})"><td><button class="tbtn" aria-label="Toggle"><i class="ti ti-chevron-right"></i></button><span class="bdg ${cat.c}">${cat.l}</span></td><td><div class="tagname">${esc(ev.tag)}</div><span class="ev-code">${esc(ev.ga4)}</span></td><td>${cepCell}</td><td><span class="bdg ${MT[ev.mt]}">${MTL[ev.mt]}</span></td></tr><tr class="dr" id="dr-${i}"><td colspan="4"><div class="di"></div></td></tr>`;
  }).join('');
  document.getElementById('shown-count').textContent=rows.length;
}
go();

